{
  "manifest_version": 3,
  "name": "GitHub на русском",
  "short_name": "GitHub RU",
  "version": "1.0.0",
  "description": "Аккуратный перевод интерфейса GitHub на русский язык. Код, имена и пользовательский контент не трогаем.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://*.github.com/*",
    "https://github.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://*.github.com/*",
        "https://github.dev/*"
      ],
      "js": [
        "src/utils/plural.js",
        "src/dictionary/common.js",
        "src/dictionary/nav.js",
        "src/dictionary/repo.js",
        "src/dictionary/pr.js",
        "src/dictionary/issues.js",
        "src/dictionary/actions.js",
        "src/dictionary/settings.js",
        "src/dictionary/profile.js",
        "src/dictionary/notifications.js",
        "src/dictionary/time.js",
        "src/dictionary/index.js",
        "src/content/guard.js",
        "src/content/translator.js",
        "src/content/content.js"
      ],
      "css": [
        "src/content/prehide.css"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "GitHub на русском",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+Shift+L",
        "mac": "Alt+Shift+L"
      },
      "description": "Включить/выключить перевод GitHub"
    }
  },
  "web_accessible_resources": []
}